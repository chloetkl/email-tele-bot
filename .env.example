TELEGRAM_BOT_TOKEN=123456:replace_me

# Used to encrypt Google OAuth refresh tokens in sqlite.
# Generate once and keep it stable:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_me

# Google OAuth client secrets JSON file downloaded from Google Cloud Console
# (OAuth client ID). Keep this file private and out of git.
GOOGLE_CLIENT_SECRETS_FILE=client_secret.json

# Optional
DATABASE_PATH=bot.db
LOG_LEVEL=INFO

# OAuth redirect base.
# - Local: keep default and open the login link on same machine.
# - Cloud Run: set to your service URL, e.g. https://<service-url>
OAUTH_REDIRECT_BASE=http://localhost:8085

# Cloud Run / webhook (recommended for hosting)
PORT=8080
BASE_URL=https://replace_me
TELEGRAM_WEBHOOK_PATH=/telegram/webhook/replace_with_random
